    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "printWidth": 120,
    "tabWidth": 4,
    "sortImports": true,
    "ignorePatterns": ["worker-configuration.d.ts"],
    "overrides": [
        {
            "files": ["*.yaml", "*.yml", "*.md"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
