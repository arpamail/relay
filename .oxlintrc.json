{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["typescript", "unicorn", "oxc", "eslint", "import"],
    "categories": {
        "correctness": "error"
    },
    "rules": {
        "typescript/restrict-template-expressions": "off"
    },
    "env": {
        "builtin": true
    },
    "options": {
        "typeAware": true,
        "typeCheck": true
    }
}
